---
---

<div class="rounded-lg border border-ink/10 bg-shell p-3">
	<p class="font-sans text-[10px] font-medium tracking-widest text-muted uppercase">
		Sketch
	</p>
	<div class="mt-2 flex flex-wrap gap-2">
		<button
			type="button"
			id="draw-tool-brush"
			class="rounded border border-ink/20 bg-page px-3 py-1.5 font-sans text-xs font-medium text-ink"
		>
			Brush
		</button>
		<button
			type="button"
			id="draw-tool-eraser"
			class="rounded border border-ink/20 px-3 py-1.5 font-sans text-xs text-muted"
		>
			Eraser
		</button>
		<button
			type="button"
			id="draw-clear"
			class="rounded border border-ink/20 px-3 py-1.5 font-sans text-xs text-muted"
		>
			Clear
		</button>
	</div>
	<canvas
		id="wish-draw-canvas"
		width="280"
		height="160"
		class="mt-3 w-full max-w-[280px] cursor-crosshair touch-none rounded border border-ink/10 bg-white"
	></canvas>
</div>
