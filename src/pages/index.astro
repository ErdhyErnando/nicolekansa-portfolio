---
import Layout from "../layouts/Layout.astro";
import Magazine from "../components/magazine/Magazine.astro";
---

<Layout title="Nicole Kansa — Portfolio" preloadCover={true}>
  <main
    class="flex min-h-dvh flex-col items-center justify-center gap-6 bg-shell px-4 py-8"
  >
    <Magazine />
    <p
      class="max-w-sm text-center font-sans text-xs leading-relaxed tracking-wide text-muted"
    >
      Swipe or tap the page corners to flip. On keyboard, use the arrow keys or
      space to browse.
    </p>
    <p
      class="max-w-sm text-center font-sans text-xs leading-relaxed tracking-wide text-muted"
    >
    </p>
  </main>
</Layout>
