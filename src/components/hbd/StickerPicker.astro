---
const stickers = [
	{ id: 'sticker-a', label: 'Sticker A' },
	{ id: 'sticker-b', label: 'Sticker B' },
	{ id: 'sticker-c', label: 'Sticker C' },
	{ id: 'sticker-d', label: 'Sticker D' }
];
---

<div class="rounded-lg border border-ink/10 bg-shell p-3">
	<p class="font-sans text-[10px] font-medium tracking-widest text-muted uppercase">
		Stickers
	</p>
	<p class="mt-1 font-sans text-xs text-muted">Select one, then tap the board to place.</p>
	<div id="sticker-picker" class="mt-3 grid grid-cols-4 gap-2">
		{
			stickers.map((s) => (
				<button
					type="button"
					class="sticker-choice flex aspect-square flex-col items-center justify-center rounded border border-ink/15 bg-placeholder p-1 font-sans text-[9px] font-medium tracking-wide text-muted uppercase transition hover:border-ink/40"
					data-sticker-id={s.id}
					data-sticker-src=""
				>
					{s.label}
				</button>
			))
		}
	</div>
</div>
