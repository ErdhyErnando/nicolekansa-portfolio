---

<div
	class="box-border flex h-full min-h-0 flex-col overflow-y-auto overflow-x-hidden bg-page p-8 text-ink"
	style="min-height: 100%; -webkit-overflow-scrolling: touch;"
>
	<h2 class="font-display text-2xl font-semibold tracking-tight">
		Works &amp; Credits
	</h2>

	<p class="mt-6 font-sans text-[10px] font-medium tracking-[0.25em] text-muted uppercase">
		Selected collaborations
	</p>

	<div class="mt-6 grid flex-1 content-start gap-8 font-sans">
		<div class="grid grid-cols-3 gap-4 sm:gap-5">
			<a
				href="https://www.instagram.com/batik.rianakesuma/"
				target="_blank"
				rel="noopener noreferrer"
				class="flex min-h-14 items-center justify-center rounded-sm outline-offset-2 transition-opacity hover:opacity-80 focus-visible:outline-2 focus-visible:outline-ink/30"
			>
				<img
					src="/images/btk.webp"
					alt="Batik Riana Kesuma on Instagram"
					class="max-h-14 w-full max-w-28 object-contain"
					loading="lazy"
				/>
			</a>
			<a
				href="https://www.instagram.com/flowday.clothes/"
				target="_blank"
				rel="noopener noreferrer"
				class="flex min-h-14 items-center justify-center rounded-sm outline-offset-2 transition-opacity hover:opacity-80 focus-visible:outline-2 focus-visible:outline-ink/30"
			>
				<img
					src="/images/flowday.webp"
					alt="Flowday on Instagram"
					class="max-h-14 w-full max-w-28 object-contain"
					loading="lazy"
				/>
			</a>
			<a
				href="https://www.instagram.com/byannisaaghina/"
				target="_blank"
				rel="noopener noreferrer"
				class="flex min-h-14 items-center justify-center rounded-sm outline-offset-2 transition-opacity hover:opacity-80 focus-visible:outline-2 focus-visible:outline-ink/30"
			>
				<img
					src="/images/bag.webp"
					alt="By Annisa Aghina on Instagram"
					class="max-h-14 w-full max-w-28 object-contain"
					loading="lazy"
				/>
			</a>
		</div>

		<div class="grid grid-cols-1 gap-3 border-t border-ink/10 pt-6 text-sm leading-snug sm:grid-cols-2">
			<a
				href="https://www.instagram.com/corriekastubi/"
				target="_blank"
				rel="noopener noreferrer"
				class="text-ink underline decoration-ink/25 underline-offset-2 transition-colors hover:decoration-ink/60 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink/30"
			>
				Cottie Kastubi
			</a>
			<a
				href="https://www.instagram.com/dimasmahendrafashion/"
				target="_blank"
				rel="noopener noreferrer"
				class="text-ink underline decoration-ink/25 underline-offset-2 transition-colors hover:decoration-ink/60 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink/30"
			>
				Dimas Mahendra
			</a>
		</div>
	</div>
</div>
