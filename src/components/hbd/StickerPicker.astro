---
const stickers = [
	{ id: "sticker-a", label: "Sticker A" },
	{ id: "sticker-b", label: "Sticker B" },
	{ id: "sticker-c", label: "Sticker C" },
	{ id: "sticker-d", label: "Sticker D" },
	{ id: "sticker-e", label: "Sticker E" },
];
---

<div class="rounded-lg border border-ink/10 bg-shell p-3">
	<p class="font-sans text-[10px] font-medium tracking-widest text-muted uppercase">
		Stickers
	</p>
	<p class="mt-1 font-sans text-xs text-muted">
		Select a stamp, tap the board to place, then use − + on the sticker to resize. Tap the
		same stamp again to cancel, or use brush/eraser to draw.
	</p>
	<div id="sticker-picker" class="mt-3 grid grid-cols-3 gap-2 sm:grid-cols-4">
		{
			stickers.map((s) => (
				<button
					type="button"
					class="sticker-choice flex aspect-square items-center justify-center overflow-hidden rounded border border-ink/15 bg-page p-0.5 transition hover:border-ink/40"
					data-sticker-id={s.id}
					aria-label={s.label}
				>
					<img
						src={`/stickers/${s.id}.webp`}
						alt=""
						class="h-full w-full object-contain"
						loading="lazy"
						draggable="false"
					/>
				</button>
			))
		}
	</div>
</div>
