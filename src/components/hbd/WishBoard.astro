---
import DrawCanvas from "./DrawCanvas.astro";
import StickerPicker from "./StickerPicker.astro";
import WishForm from "./WishForm.astro";
import WishCard from "./WishCard.astro";
---

<div class="relative min-h-dvh bg-shell px-4 py-10 text-ink">
  <a
    href="/"
    class="group absolute left-4 top-10 z-10 inline-flex items-center gap-2 rounded-md px-2 py-1.5 font-sans text-sm font-medium text-ink/75 transition-colors hover:text-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink/35"
    aria-label="Back to magazine"
  >
    <span
      class="text-lg leading-none transition-transform group-hover:-translate-x-0.5"
      aria-hidden="true">←</span
    >
    <span class="hidden sm:inline">Magazine</span>
  </a>
  <header class="mx-auto max-w-6xl text-center">
    <p
      class="font-sans text-[10px] font-medium tracking-[0.35em] text-muted uppercase"
    >
      Birthday board 🥳
    </p>
    <h1
      class="font-display mt-2 text-4xl font-semibold tracking-tight md:text-5xl"
    >
      Wishes for Nicole
    </h1>
    <p class="mx-auto mt-3 max-w-lg font-sans text-sm text-muted">
      Leave a note, doodle, and add stickers on your personal whiteboard. It all
      shows up on the main board for everyone.
    </p>
  </header>

  <div
    class="mx-auto mt-10 grid max-w-6xl gap-8 lg:grid-cols-[minmax(0,1fr)_340px] lg:items-start"
  >
    <section
      class="relative min-h-[420px] rounded-2xl border border-ink/10 bg-page shadow-inner"
    >
      <div
        id="wish-pinboard"
        class="relative min-h-[420px] w-full bg-[#f3f0eb] pb-8"
        aria-label="Wish board"
      >
        <p
          id="wish-board-empty"
          class="pointer-events-none absolute inset-0 flex items-center justify-center p-6 text-center font-sans text-sm text-muted"
        >
          No wishes yet — be the first.
        </p>
      </div>
    </section>

    <aside class="space-y-4 lg:sticky lg:top-8">
      <WishForm />
      <div
        class="space-y-3 rounded-lg border border-ink/10 bg-shell p-3 shadow-sm"
      >
        <div>
          <p
            class="font-sans text-[10px] font-medium tracking-widest text-muted uppercase"
          >
            Your wish board
          </p>
          <p class="mt-1 font-sans text-xs leading-relaxed text-muted">
            Draw with the tools below. Pick a stamp, tap the board to place it,
            then drag, resize (− +), or remove (×). Use brush or eraser anytime
            — or tap the same stamp again to cancel placement.
          </p>
        </div>
        <div
          id="compose-board"
          class="relative h-80 min-h-[200px] w-full touch-none overflow-hidden rounded-lg border border-ink/15 bg-white shadow-inner"
        >
          <canvas
            id="wish-draw-canvas"
            class="absolute inset-0 z-1 h-full w-full cursor-crosshair touch-none"
            width="1"
            height="1"
            aria-label="Doodle on your wish"
          />
        </div>
        <DrawCanvas />
        <StickerPicker />
      </div>
    </aside>
  </div>
</div>

<WishCard />

<script>
  import type { WishRecord } from "../../types/wish";

  const pinboard = document.getElementById("wish-pinboard");
  const composeBoard = document.getElementById("compose-board");
  const template = document.getElementById(
    "wish-card-template",
  ) as HTMLTemplateElement | null;
  const emptyHint = document.getElementById("wish-board-empty");
  const form = document.getElementById("wish-form") as HTMLFormElement | null;
  const nameInput = document.getElementById(
    "wish-name",
  ) as HTMLInputElement | null;
  const messageInput = document.getElementById(
    "wish-message",
  ) as HTMLTextAreaElement | null;
  const charCount = document.getElementById("wish-char-count");
  const formStatus = document.getElementById("wish-form-status");
  const submitBtn = document.getElementById(
    "wish-submit",
  ) as HTMLButtonElement | null;
  const canvas = document.getElementById(
    "wish-draw-canvas",
  ) as HTMLCanvasElement | null;
  const btnBrush = document.getElementById("draw-tool-brush");
  const btnEraser = document.getElementById("draw-tool-eraser");
  const btnClear = document.getElementById("draw-clear");
  const drawBrushSize = document.getElementById(
    "draw-brush-size",
  ) as HTMLInputElement | null;
  const drawEraserSize = document.getElementById(
    "draw-eraser-size",
  ) as HTMLInputElement | null;
  const drawBrushSizeVal = document.getElementById("draw-brush-size-value");
  const drawEraserSizeVal = document.getElementById("draw-eraser-size-value");
  const drawColorCustom = document.getElementById(
    "draw-color-custom",
  ) as HTMLInputElement | null;
  const drawSwatches =
    document.querySelectorAll<HTMLElement>("[data-draw-swatch]");

  let selectedStickerId: string | null = null;
  let drawingTool: "brush" | "eraser" = "brush";
  let isDrawing = false;
  let hasInk = false;
  let brushColor = "#0a0a0a";
  let brushSize = 4;
  let eraserSize = 10;

  function clearStickerSelection() {
    selectedStickerId = null;
    document.querySelectorAll(".sticker-choice").forEach((b) => {
      b.classList.remove("ring-2", "ring-ink", "ring-offset-2");
    });
  }

  function setTool(t: "brush" | "eraser") {
    clearStickerSelection();
    drawingTool = t;
    btnBrush?.classList.toggle("bg-page", t === "brush");
    btnBrush?.classList.toggle("font-medium", t === "brush");
    btnEraser?.classList.toggle("bg-page", t === "eraser");
    btnEraser?.classList.toggle("font-medium", t === "eraser");
  }

  function syncCanvasToLayout() {
    if (!canvas || !composeBoard) return;
    const dpr = window.devicePixelRatio || 1;
    const r = composeBoard.getBoundingClientRect();
    const nextW = Math.max(1, Math.round(r.width * dpr));
    const nextH = Math.max(1, Math.round(r.height * dpr));
    if (nextW < 1 || nextH < 1) return;
    if (canvas.width === nextW && canvas.height === nextH) return;
    const g0 = canvas.getContext("2d");
    if (!g0) return;
    const tmp = document.createElement("canvas");
    tmp.width = canvas.width;
    tmp.height = canvas.height;
    if (tmp.width > 0 && tmp.height > 0) {
      const tg = tmp.getContext("2d");
      if (tg) tg.drawImage(canvas, 0, 0);
    }
    canvas.width = nextW;
    canvas.height = nextH;
    const g = canvas.getContext("2d");
    if (g) {
      g.lineCap = "round";
      g.lineJoin = "round";
      if (tmp.width > 0 && tmp.height > 0) {
        g.drawImage(tmp, 0, 0, nextW, nextH);
      }
    }
  }

  function setupCanvas() {
    if (!canvas) return;
    const c: HTMLCanvasElement = canvas;
    function getG() {
      return c.getContext("2d");
    }
    const gInit = getG();
    if (!gInit) return;
    gInit.lineCap = "round";
    gInit.lineJoin = "round";

    brushSize = drawBrushSize
      ? Math.max(1, Math.min(24, parseInt(drawBrushSize.value, 10) || 4))
      : 4;
    eraserSize = drawEraserSize
      ? Math.max(2, Math.min(40, parseInt(drawEraserSize.value, 10) || 10))
      : 10;
    if (drawBrushSizeVal) drawBrushSizeVal.textContent = String(brushSize);
    if (drawEraserSizeVal) drawEraserSizeVal.textContent = String(eraserSize);
    if (drawColorCustom) {
      drawColorCustom.value = brushColor;
    }

    function setSwatchPressed(el: HTMLElement | null) {
      drawSwatches.forEach((sw) => {
        sw.setAttribute("aria-pressed", el === sw ? "true" : "false");
      });
    }

    drawSwatches.forEach((sw) => {
      sw.addEventListener("click", () => {
        const hex = sw.dataset.color;
        if (!hex) return;
        brushColor = hex;
        if (drawColorCustom) drawColorCustom.value = hex;
        setSwatchPressed(sw);
      });
    });
    if (drawSwatches[0]) {
      setSwatchPressed(drawSwatches[0]);
    }
    drawColorCustom?.addEventListener("input", () => {
      brushColor = drawColorCustom.value;
      setSwatchPressed(null);
    });

    drawBrushSize?.addEventListener("input", () => {
      const v = parseInt(drawBrushSize.value, 10);
      brushSize = Math.max(1, Math.min(24, Number.isFinite(v) ? v : 4));
      if (drawBrushSizeVal) drawBrushSizeVal.textContent = String(brushSize);
    });
    drawEraserSize?.addEventListener("input", () => {
      const v = parseInt(drawEraserSize.value, 10);
      eraserSize = Math.max(2, Math.min(40, Number.isFinite(v) ? v : 10));
      if (drawEraserSizeVal) drawEraserSizeVal.textContent = String(eraserSize);
    });

    let last: { x: number; y: number } | null = null;

    function pos(e: PointerEvent) {
      const r = c.getBoundingClientRect();
      const scaleX = c.width / r.width;
      const scaleY = c.height / r.height;
      return {
        x: (e.clientX - r.left) * scaleX,
        y: (e.clientY - r.top) * scaleY,
      };
    }

    function start(e: PointerEvent) {
      if (!e.isPrimary) return;
      if (selectedStickerId && composeBoard) {
        const r = composeBoard.getBoundingClientRect();
        const nx = (e.clientX - r.left) / r.width;
        const ny = (e.clientY - r.top) / r.height;
        makeComposeSticker(selectedStickerId, nx, ny);
        clearStickerSelection();
        e.preventDefault();
        return;
      }
      c.setPointerCapture(e.pointerId);
      isDrawing = true;
      hasInk = true;
      last = pos(e);
    }

    function drawLine(e: PointerEvent) {
      if (!isDrawing || !last) return;
      const g = getG();
      if (!g) return;
      const p = pos(e);
      g.save();
      g.lineWidth = drawingTool === "eraser" ? eraserSize : brushSize;
      if (drawingTool === "eraser") {
        g.globalCompositeOperation = "destination-out";
        g.strokeStyle = "rgba(0,0,0,1)";
      } else {
        g.globalCompositeOperation = "source-over";
        g.strokeStyle = brushColor;
      }
      g.beginPath();
      g.moveTo(last.x, last.y);
      g.lineTo(p.x, p.y);
      g.stroke();
      g.restore();
      last = p;
    }

    function end(e: PointerEvent) {
      if (!e.isPrimary) return;
      isDrawing = false;
      last = null;
      try {
        c.releasePointerCapture(e.pointerId);
      } catch {
        /* noop */
      }
    }

    c.addEventListener("pointerdown", start);
    c.addEventListener("pointermove", drawLine);
    c.addEventListener("pointerup", end);
    c.addEventListener("pointercancel", end);

    btnBrush?.addEventListener("click", () => {
      setTool("brush");
    });
    btnEraser?.addEventListener("click", () => {
      setTool("eraser");
    });
    btnClear?.addEventListener("click", () => {
      const g = getG();
      g?.clearRect(0, 0, c.width, c.height);
      hasInk = false;
    });
    setTool("brush");
    syncCanvasToLayout();
    if (typeof ResizeObserver !== "undefined" && composeBoard) {
      const ro = new ResizeObserver(() => {
        syncCanvasToLayout();
      });
      ro.observe(composeBoard);
    }
  }

  function getDrawingDataUrl(): string | null {
    if (!canvas || !hasInk) return null;
    try {
      return canvas.toDataURL("image/png");
    } catch {
      return null;
    }
  }

  function stickerSrcForId(id: string): string {
    return `/stickers/${id}.webp`;
  }

  const STICKER_SCALE_MIN = 0.4;
  const STICKER_SCALE_MAX = 2;
  const STICKER_SCALE_STEP = 0.15;

  type Placement = { id: string; el: HTMLElement; x: number; y: number; scale: number };

  const composePlacements: Placement[] = [];

  function applyStickerTransform(el: HTMLElement, scale: number) {
    el.dataset.stickerScale = String(scale);
    el.style.transform = `translate(-50%, -50%) scale(${scale})`;
  }

  function adjustStickerScale(stickerEl: HTMLElement, id: string, delta: number) {
    const p = composePlacements.find((q) => q.el === stickerEl);
    if (!p) return;
    const next = Math.min(
      STICKER_SCALE_MAX,
      Math.max(STICKER_SCALE_MIN, p.scale + delta),
    );
    p.scale = next;
    applyStickerTransform(stickerEl, next);
    syncPlacementFromEl(stickerEl, id);
  }

  function syncPlacementFromEl(el: HTMLElement, id: string) {
    if (!composeBoard) return;
    const r = composeBoard.getBoundingClientRect();
    const er = el.getBoundingClientRect();
    const cx = er.left + er.width / 2 - r.left;
    const cy = er.top + er.height / 2 - r.top;
    let x = cx / r.width;
    let y = cy / r.height;
    x = Math.min(1, Math.max(0, x));
    y = Math.min(1, Math.max(0, y));
    const p = composePlacements.find((q) => q.el === el);
    if (p) {
      p.x = x;
      p.y = y;
      p.id = id;
      const sc = parseFloat(el.dataset.stickerScale || "1");
      if (Number.isFinite(sc)) p.scale = sc;
    }
  }

  function removeComposeSticker(stickerEl: HTMLElement) {
    const i = composePlacements.findIndex((p) => p.el === stickerEl);
    if (i >= 0) composePlacements.splice(i, 1);
    stickerEl.remove();
  }

  function makeComposeSticker(id: string, nx: number, ny: number) {
    if (!composeBoard) return;
    const initialScale = 1;
    const el = document.createElement("div");
    el.className =
      "compose-sticker group absolute z-20 flex h-11 w-11 cursor-grab items-center justify-center rounded border border-ink/20 bg-placeholder/80 shadow-sm backdrop-blur-[1px] active:cursor-grabbing";
    el.style.left = `${nx * 100}%`;
    el.style.top = `${ny * 100}%`;
    el.dataset.stickerId = id;
    applyStickerTransform(el, initialScale);
    const img = document.createElement("img");
    img.src = stickerSrcForId(id);
    img.alt = "";
    img.className =
      "pointer-events-none absolute inset-0 h-full w-full rounded object-contain p-0.5";
    img.onerror = () => {
      img.remove();
    };
    const rm = document.createElement("button");
    rm.type = "button";
    rm.className =
      "sticker-remove pointer-events-auto absolute -right-1.5 -top-1.5 z-[30] flex h-5 w-5 items-center justify-center rounded-full border border-ink/20 bg-page font-sans text-[10px] font-semibold leading-none text-ink/70 shadow";
    rm.setAttribute("aria-label", "Remove sticker");
    rm.textContent = "×";
    rm.addEventListener("pointerdown", (e) => e.stopPropagation());
    rm.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      removeComposeSticker(el);
    });
    const scaleRow = document.createElement("div");
    scaleRow.className =
      "sticker-scale-row pointer-events-auto absolute bottom-0 left-0 right-0 z-[30] flex items-center justify-center gap-0.5 pb-0.5";
    const mkScaleBtn = (label: string, delta: number) => {
      const b = document.createElement("button");
      b.type = "button";
      b.className =
        "flex h-4 w-4 items-center justify-center rounded border border-ink/20 bg-page font-sans text-[10px] font-semibold leading-none text-ink/80 shadow-sm";
      b.textContent = label;
      b.setAttribute(
        "aria-label",
        delta < 0 ? "Shrink sticker" : "Grow sticker",
      );
      b.addEventListener("pointerdown", (e) => e.stopPropagation());
      b.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        adjustStickerScale(el, id, delta);
      });
      return b;
    };
    scaleRow.appendChild(mkScaleBtn("−", -STICKER_SCALE_STEP));
    scaleRow.appendChild(mkScaleBtn("+", STICKER_SCALE_STEP));
    el.appendChild(img);
    el.appendChild(rm);
    el.appendChild(scaleRow);
    composeBoard.appendChild(el);
    composePlacements.push({ id, el, x: nx, y: ny, scale: initialScale });
    dragSticker(el, id);
  }

  function dragSticker(el: HTMLElement, id: string) {
    let startX = 0;
    let startY = 0;
    let origLeft = 0;
    let origTop = 0;
    el.addEventListener("pointerdown", (e) => {
      if (!composeBoard || e.button !== 0) return;
      const t = e.target as HTMLElement;
      if (t.closest?.(".sticker-remove") || t.closest?.(".sticker-scale-row")) {
        return;
      }
      e.stopPropagation();
      el.setPointerCapture(e.pointerId);
      const r = composeBoard.getBoundingClientRect();
      const er = el.getBoundingClientRect();
      startX = e.clientX;
      startY = e.clientY;
      origLeft = er.left + er.width / 2 - r.left;
      origTop = er.top + er.height / 2 - r.top;
    });
    el.addEventListener("pointermove", (e) => {
      if (!el.hasPointerCapture(e.pointerId) || !composeBoard) return;
      const r = composeBoard.getBoundingClientRect();
      let cx = origLeft + (e.clientX - startX);
      let cy = origTop + (e.clientY - startY);
      cx = Math.max(0, Math.min(r.width, cx));
      cy = Math.max(0, Math.min(r.height, cy));
      el.style.left = `${(cx / r.width) * 100}%`;
      el.style.top = `${(cy / r.height) * 100}%`;
      syncPlacementFromEl(el, id);
    });
    el.addEventListener("pointerup", (e) => {
      if (el.hasPointerCapture(e.pointerId)) {
        el.releasePointerCapture(e.pointerId);
        syncPlacementFromEl(el, id);
      }
    });
  }

  function setupPicker() {
    document.querySelectorAll(".sticker-choice").forEach((btn) => {
      btn.addEventListener("click", () => {
        const el = btn as HTMLElement;
        const id = el.dataset.stickerId ?? null;
        const isToggleOff =
          id !== null &&
          selectedStickerId === id &&
          el.classList.contains("ring-2");
        document.querySelectorAll(".sticker-choice").forEach((b) => {
          b.classList.remove("ring-2", "ring-ink", "ring-offset-2");
        });
        if (isToggleOff) {
          selectedStickerId = null;
          return;
        }
        el.classList.add("ring-2", "ring-ink", "ring-offset-2");
        selectedStickerId = id;
      });
    });
  }

  function formatTime(iso: string) {
    try {
      const d = new Date(iso);
      return d.toLocaleDateString(undefined, {
        month: "short",
        day: "numeric",
      });
    } catch {
      return "";
    }
  }

  const PINBOARD_MIN_PX = 420;
  const PINBOARD_BOTTOM_PAD = 40;

  /** Each tap raises z-index so overlapped text/stickers can be read (starts above pinboard empty hint). */
  let wishCardZCounter = 50;

  function bringWishCardToFront(card: HTMLElement) {
    if (!pinboard) return;
    pinboard.querySelectorAll(".wish-card").forEach((el) => {
      el.classList.remove(
        "ring-2",
        "ring-ink/35",
        "shadow-lg",
        "brightness-[1.02]",
      );
    });
    wishCardZCounter += 1;
    card.style.zIndex = String(wishCardZCounter);
    card.classList.add(
      "ring-2",
      "ring-ink/35",
      "shadow-lg",
      "brightness-[1.02]",
    );
  }

  function dragWishCard(card: HTMLElement) {
    let startX = 0;
    let startY = 0;
    let origLeftPx = 0;
    let origTopPx = 0;

    card.addEventListener("pointerdown", (e) => {
      if (!pinboard || !e.isPrimary || e.button !== 0) return;
      bringWishCardToFront(card);
      card.classList.add("cursor-grabbing", "select-none", "touch-none");
      card.setPointerCapture(e.pointerId);
      const pr = pinboard.getBoundingClientRect();
      const er = card.getBoundingClientRect();
      startX = e.clientX;
      startY = e.clientY;
      origLeftPx = er.left - pr.left;
      origTopPx = er.top - pr.top;
    });

    card.addEventListener("pointermove", (e) => {
      if (!pinboard || !card.hasPointerCapture(e.pointerId)) return;
      const pr = pinboard.getBoundingClientRect();
      const w = card.offsetWidth;
      const h = card.offsetHeight;
      const maxLeft = Math.max(0, pr.width - w);
      const maxTop = Math.max(0, pr.height - h);
      let newLeft = origLeftPx + (e.clientX - startX);
      let newTop = origTopPx + (e.clientY - startY);
      newLeft = Math.max(0, Math.min(maxLeft, newLeft));
      newTop = Math.max(0, Math.min(maxTop, newTop));
      card.style.left = `${(newLeft / pr.width) * 100}%`;
      card.style.top = `${(newTop / pr.height) * 100}%`;
    });

    function endDrag(e: PointerEvent) {
      if (!card.hasPointerCapture(e.pointerId)) return;
      card.releasePointerCapture(e.pointerId);
      card.classList.remove("cursor-grabbing", "select-none", "touch-none");
      requestAnimationFrame(() => syncPinboardHeight());
    }

    card.addEventListener("pointerup", endDrag);
    card.addEventListener("pointercancel", endDrag);
  }

  /**
   * Cards use % top/height, so changing minHeight shifts layout. At most two
   * measure→write passes sync; a third runs next frame if still short (avoids
   * long read/write loops in one frame).
   */
  function syncPinboardHeight() {
    if (!pinboard) return;
    const cards = pinboard.querySelectorAll(".wish-card");
    if (cards.length === 0) {
      pinboard.style.minHeight = "";
      return;
    }

    const measureNeed = (): number => {
      const pr = pinboard!.getBoundingClientRect();
      let maxBottom = 0;
      cards.forEach((el) => {
        const r = el.getBoundingClientRect();
        maxBottom = Math.max(maxBottom, r.bottom - pr.top);
      });
      return Math.max(
        PINBOARD_MIN_PX,
        Math.ceil(maxBottom + PINBOARD_BOTTOM_PAD),
      );
    };

    let need = measureNeed();
    pinboard.style.minHeight = `${need}px`;
    const afterGrow = measureNeed();
    if (afterGrow <= need + 1) return;
    pinboard.style.minHeight = `${afterGrow}px`;
    requestAnimationFrame(() => {
      const finalNeed = measureNeed();
      if (finalNeed > afterGrow + 1) {
        pinboard!.style.minHeight = `${finalNeed}px`;
      }
    });
  }

  function renderWishCard(w: WishRecord, index: number) {
    if (!pinboard || !template) return;
    const node = template.content.firstElementChild?.cloneNode(
      true,
    ) as HTMLElement;
    if (!node) return;

    const cols = 3;
    const col = index % cols;
    const row = Math.floor(index / cols);
    node.style.left = `${6 + col * 30}%`;
    node.style.top = `${4 + row * 30}%`;
    node.style.zIndex = String(10 + index);
    node.style.setProperty("--rot", `${((index % 5) - 2) * 1.8}deg`);
    node.setAttribute(
      "aria-label",
      `Wish from ${w.name}. Drag to move on the board. Tap or press Enter to bring to front.`,
    );

    const nameEl = node.querySelector(".wish-card-name");
    const timeEl = node.querySelector(".wish-card-time");
    const msgEl = node.querySelector(".wish-card-message");
    const stickerRegion = node.querySelector(".wish-card-stickers");
    const drawEl = node.querySelector(
      ".wish-card-drawing",
    ) as HTMLImageElement | null;

    if (nameEl) nameEl.textContent = w.name;
    if (timeEl) timeEl.textContent = formatTime(w.createdAt);
    if (msgEl) msgEl.textContent = w.message;

    if (stickerRegion && w.stickers?.length) {
      stickerRegion.innerHTML = "";
      for (const s of w.stickers) {
        const sc =
          typeof s.scale === "number" && Number.isFinite(s.scale) ? s.scale : 1;
        const mark = document.createElement("div");
        mark.className =
          "absolute h-6 w-6 overflow-hidden rounded border border-ink/15 bg-shell";
        mark.style.left = `${s.x * 100}%`;
        mark.style.top = `${s.y * 100}%`;
        mark.style.transform = `translate(-50%, -50%) scale(${sc})`;
        const im = document.createElement("img");
        im.src = stickerSrcForId(s.id);
        im.alt = "";
        im.className = "h-full w-full object-contain p-0.5";
        im.onerror = () => {
          mark.textContent = "★";
          mark.classList.add(
            "flex",
            "items-center",
            "justify-center",
            "text-[10px]",
          );
        };
        mark.appendChild(im);
        stickerRegion.appendChild(mark);
      }
    }

    if (drawEl && w.drawing) {
      drawEl.src = w.drawing;
      drawEl.classList.remove("hidden");
      drawEl.addEventListener(
        "load",
        () => {
          requestAnimationFrame(() => syncPinboardHeight());
        },
        { once: true },
      );
    }

    dragWishCard(node);
    node.addEventListener("keydown", (e) => {
      if (
        e.key === "Enter" ||
        e.key === " " ||
        e.code === "Space" ||
        e.code === "Spacebar"
      ) {
        e.preventDefault();
        bringWishCardToFront(node);
      }
    });

    pinboard.appendChild(node);
  }

  async function loadWishes() {
    if (!pinboard) return;
    try {
      const res = await fetch("/api/wishes");
      const data = (await res.json()) as WishRecord[];
      pinboard.querySelectorAll(".wish-card").forEach((n) => n.remove());
      if (!Array.isArray(data) || data.length === 0) {
        emptyHint?.classList.remove("hidden");
        return;
      }
      emptyHint?.classList.add("hidden");
      data.forEach((w, i) => renderWishCard(w, i));
      requestAnimationFrame(() => {
        requestAnimationFrame(() => syncPinboardHeight());
      });
    } catch {
      emptyHint?.classList.remove("hidden");
    }
  }

  function collectStickers(): { id: string; x: number; y: number; scale?: number }[] {
    return composePlacements.map((p) => {
      const o: { id: string; x: number; y: number; scale?: number } = {
        id: p.id,
        x: p.x,
        y: p.y,
      };
      if (p.scale < 0.99 || p.scale > 1.01) o.scale = p.scale;
      return o;
    });
  }

  function resetCompose() {
    composePlacements.length = 0;
    composeBoard
      ?.querySelectorAll(".compose-sticker")
      .forEach((n) => n.remove());
    if (canvas) {
      const ctx = canvas.getContext("2d");
      ctx?.clearRect(0, 0, canvas.width, canvas.height);
      hasInk = false;
    }
  }

  function setupForm() {
    messageInput?.addEventListener("input", () => {
      if (charCount && messageInput) {
        charCount.textContent = `${messageInput.value.length} / 280`;
      }
    });

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!nameInput || !messageInput || !submitBtn) return;
      formStatus?.classList.add("hidden");
      submitBtn.disabled = true;
      const body = {
        name: nameInput.value.trim(),
        message: messageInput.value.trim(),
        stickers: collectStickers(),
        drawing: getDrawingDataUrl(),
      };
      try {
        const res = await fetch("/api/wishes", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          const msg =
            typeof data === "object" && data && "error" in data
              ? String((data as { error: string }).error)
              : "Could not save wish";
          throw new Error(msg);
        }
        formStatus?.classList.remove("hidden", "text-red-600");
        formStatus?.classList.add("text-muted");
        if (formStatus) formStatus.textContent = "Sent! Thank you.";
        form.reset();
        if (charCount) charCount.textContent = "0 / 280";
        resetCompose();
        await loadWishes();
      } catch (err) {
        formStatus?.classList.remove("hidden", "text-muted");
        formStatus?.classList.add("text-red-600");
        if (formStatus) {
          formStatus.textContent =
            err instanceof Error ? err.message : "Something went wrong";
        }
      } finally {
        submitBtn.disabled = false;
      }
    });
  }

  setupCanvas();
  setupPicker();
  setupForm();
  void loadWishes();

  let resizeT: ReturnType<typeof setTimeout> | undefined;
  window.addEventListener("resize", () => {
    clearTimeout(resizeT);
    resizeT = setTimeout(() => syncPinboardHeight(), 120);
  });
</script>
