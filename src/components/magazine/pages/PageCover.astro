---

---

<div
  class="relative h-full w-full overflow-hidden bg-page"
  style="min-height: 100%;"
>
  <div class="absolute inset-0 z-0 bg-placeholder" aria-hidden="true">
    <span
      class="absolute bottom-4 right-4 font-sans text-xs tracking-widest text-muted uppercase"
    >
      450 × 643 © placeholder
    </span>
  </div>
  <img
    src="/images/magazine/cover.webp"
    alt=""
    width="450"
    height="643"
    class="absolute inset-0 z-1 h-full w-full object-cover scale-[1.8] translate-y-[-15%]"
    loading="eager"
    fetchpriority="high"
    onerror="this.remove()"
  />
  <div
    class="pointer-events-none absolute inset-x-0 top-0 z-3 px-3 pt-4 md:px-4 md:pt-6"
  >
    <div class="relative">
      <h1
        class="font-masthead text-center text-[4.85rem] font-extrabold uppercase leading-[0.82] tracking-[-0.03em] text-white drop-shadow-[0_2px_10px_rgba(0,0,0,0.35)] sm:text-6xl md:text-[3.85rem]"
      >
        NICOLE
      </h1>
      <p
        class="absolute -right-0.5 top-0 max-w-22 text-right font-sans text-[9px] font-semibold uppercase leading-tight tracking-[0.22em] text-white drop-shadow-[0_1px_6px_rgba(0,0,0,0.4)] sm:text-[10px] md:right-0 md:top-1 md:text-[11px] md:tracking-[0.26em]"
      >
        KANSA
      </p>
    </div>
    <p
      class="mt-5 max-w-76 pl-0.5 text-left font-sans text-[10px] font-normal uppercase leading-relaxed tracking-[0.14em] text-white drop-shadow-[0_1px_6px_rgba(0,0,0,0.4)] sm:text-[11px] md:mt-6 md:max-w-[21rem] md:tracking-[0.16em]"
    >
      living it with self-trust, clarity, and unapologetic ownership.
    </p>
  </div>
</div>
